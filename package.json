{
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freylint/freyground.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/freylint/freyground/issues"
  },
  "homepage": "https://quak.dev",
  "jest": {
    "verbose": true,
    "testMatch": [
      "**/*.steps.[tj]s",
      "**/*.spec.[tj]s"
    ],
    "transform": {
      "^.+\\.jsx?$": "babel-jest"
    }
  },
  "scripts": {
    "test": "jest",
    "build": "npm run build-docs && npm run build-runtime && npm run build-model",
    "build-runtime": "cargo b -r --manifest-path projects/fg-runtime/Cargo.toml --target-dir ./build/",
    "build-model": "cargo b -r --manifest-path projects/fg-model/Cargo.toml --target-dir ./build/ --target wasm32-unknown-unknown",
    "build-docs": "node scripts/docbuild.js",
    "spell-docs": "textlint docs/*.md"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.20.2",
    "@cucumber/cucumber": "^8.9.0",
    "gulp": "^4.0.2",
    "jest": "^29.3.1",
    "jest-cucumber": "^3.0.1",
    "markdown-it": "^13.0.1",
    "markdown-it-include": "^2.0.0",
    "markdown-it-textual-uml": "^0.12.0",
    "textlint": "^12.2.3",
    "textlint-rule-en-spell": "^1.2.4"
  },
  "dependencies": {
    "@wasmer/wasi": "^1.2.2"
  }
}
