{
  "name": "acceptance",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "description": "Freyground monorepo acceptance testing.",
  "private": true,
  "scripts": {
    "test": "jest"
  },
  "dependencies": {
    "smi": "*"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.20.2",
    "@cucumber/cucumber": "^8.9.0",
    "jest": "^29.3.1",
    "jest-cucumber": "^3.0.1"
  },
  "jest": {
    "verbose": true,
    "testMatch": [
      "**/*.steps.[tj]s",
      "**/*.spec.[tj]s"
    ],
    "transform": {
      "^.+\\.jsx?$": "babel-jest"
    }
  }
}
