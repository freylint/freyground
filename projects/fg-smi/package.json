{
  "name": "fg-smi",
  "version": "0.0.1",
  "description": "Standard messaging interface for freyground.com microservices.",
  "devDependencies": {},
  "scripts": {
    "build": "cargo b -r --target-dir ../../build/ --target wasm32-unknown-unknown",
    "package": "mkdir -p ../../dist/bin/ && cp ../../build/wasm32-unknown-unknown/release/fg_smi.wasm ../../dist/bin/",
    "test": "cargo test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freylint/freyground.git"
  },
  "author": "Freylint",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/freylint/freyground/issues"
  },
  "homepage": "https://github.com/freylint/freyground#readme",
  "build": {
    "dependsOn": [
      {
        "projects": "fg-runtime",
        "target": "build"
      }
    ]
  }
}
