{
  "name": "fg-runtime",
  "version": "0.0.1",
  "description": "Backend runtime for freyground.com",
  "scripts": {
    "build": "cargo b -r --target-dir ../../build/",
    "lint": "cargo clippy -- -Dwarnings",
    "package": "mkdir -p ../../dist && cp ../../build/release/fg-runtime ../../dist/",
    "test": "cargo test",
    "run": "cd ../../dist && ./fg-runtime"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freylint/freyground.git"
  },
  "author": "Freylint",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/freylint/freyground/issues"
  },
  "homepage": "https://github.com/freylint/freyground#readme",
  "outputs": [
    "../../build/release/fg-runtime",
    "../../dist/fg-runtime"
  ],
  "package": {
    "dependsOn": [
      {
        "projects": "self",
        "target": "build"
      }
    ]
  },
  "run": {
    "dependsOn": [
      {
        "projects": "self",
        "target": "package"
      },
      {
        "projects": "fg-smi",
        "target": "fg-smi:package"
      }
    ]
  }
}
